@{
    ViewData["Title"] = "Employee Details";
    var emp = Context.Session.GetString("EmployeeDetails");
}
<!-- Bootstrap JS bundle (includes Popper) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.js"></script>

<!-- Bootstrap Icons CSS CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<!-- jQuery (if not already included) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<link href="~/css/customcss.css" rel="stylesheet" />
<link href="~/css/sb-admin-2.min.css" rel="stylesheet" />

<div id="page-top">
    <!-- Page Wrapper -->
    <div id="wrapper">
        <!-- Content Wrapper -->
        <div id="content-wrapper" class="d-flex flex-column" style="overflow-x: hidden;">
            <!-- Main Content -->
            <div id="content">
                <h6 class="text-left h6 text-gray-900" style="font-size: x-large; color: black; margin: 0; padding: 0;" data-i18n="Index.empma_pTitle"></h6>

                <!-- Begin Page Content -->
                <div class="container-fluid" style="border: none; background: none; cursor: pointer;">

                    <!-- Search Panel -->
                    <div class="card p-1 shadow-sm mb-1">
                        <div class="row g-3">
                            <div class="col-md-10">
                                <input type="text" id="txtSearch" class="form-control" placeholder="search by emp code, name, dept, country" style="border:none;" />
                            </div>
                            <div class="col-md-1 ml-auto">
                                <div class="d-flex justify-content-end align-items-center">

                                    <button id="btnexposrtCSV" onclick="exportTableToCSV()" title="Export to CSV" class="btn btn-link p-0 mr-3">
                                        <i class="fa" style="color:blueviolet;">&#xf15b;</i>
                                    </button>

                                    <button id="btnexposrtExcel" onclick="exportTableToExcel()" title="Export to Excel" class="btn btn-link p-0 mr-3">
                                        <i class="fa fa-file-excel-o" style="color:red;"></i>
                                    </button>

                                    <a href="/EmpMaster/EmpRegisteration" title="Add new employee" class="btn btn-link p-0">
                                        <i class="fa fa-user-plus" style="color:dodgerblue;" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <div>
                            <select class="form-control" id="pageSizeSelect">
                                <option value="50">50</option>
                                <option value="1005">100</option>
                                <option value="150">150</option>
                                <option value="All">All</option>
                            </select>
                        </div>
                        
                        <div class="fw-bold" style="display: flex; align-items: center;">
                            <h6 data-i18n="Index.empma_ptotalrecordcount" style="margin: 0;"></h6>
                            <span id="totalCount" style="margin-left: 5px;">0</span>
                        </div>
                        <!-- Pagination Controls -->
                        <div>
                            <button onclick="prevPage()" style="border: none; background: none; cursor: pointer;"><i class="fa fa-backward"></i></button>
                            <span id="currentPage" style="border: none; background: none; cursor: pointer;">1</span>
                            <button onclick="nextPage()" style="border: none; background: none; cursor: pointer;"><i class="fa fa-forward" aria-hidden="true"></i></button>
                        </div>
                    </div>

                    <!-- Table -->
                    <div class="table-responsive shadow-sm" style="overflow-x: hidden;">
                        <table id="empTable" class="table table-bordered table-hover table-sm" style="font-size: 11px;">
                            <thead class="table-secondary">
                                <tr>
                                    <th data-i18n="Index.empma_tableSno"></th>
                                    <th onclick="sortTable('empcode')">empCode&nbsp;<i class="bi bi-arrow-down-up"></i></th>
                                    <th onclick="sortTable('empName')">empName&nbsp;<i class="bi bi-arrow-down-up"></i></i></th>
                                    <th onclick="sortTable('department')">Department&nbsp;<i class="bi bi-arrow-down-up"></i></th>
                                    <th onclick="sortTable('subDepartment')">subDepartment&nbsp;<i class="bi bi-arrow-down-up"></i></th>
                                    <th onclick="sortTable('section')">Section&nbsp;<i class="bi bi-arrow-down-up"></i></th>
                                    <th>DOJ&nbsp;</th>
                                    <th onclick="sortTable('designation')"> Designation&nbsp;<i class="bi bi-arrow-down-up"></i></th>
                                    <th>Gender&nbsp;</th>
                                    <th onclick="sortTable('nationality')">Country&nbsp;<i class="bi bi-arrow-down-up"></i></th>
                                    <th onclick="sortTable('educationLevel')">Education<i class="bi bi-arrow-down-up"></i></th>
                                    <th style="width: 112px; max-width: 112px; white-space: nowrap;">Action</th>
                                </tr>
                            </thead>
                            <tbody id="empBody"></tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <span id="totalCount" class="badge bg-dark p-2"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    #empTable thead th {
        background-color: #6c757d !important;
     color: white !important;

    }
</style>
@section Scripts {
    <script>
        const employeeSession = '@emp';
    </script>
    <script src="~/js/jsemployee/jsempmasterlst.js"></script>
    <script src="~/js/jsemployee/ejs_empregisteration.js"></script>
}
