        border: 2px green;
    }

    .dropdown-item.active {
        background-color: #0d6efd;
        color: white;
    }

    #divlicensetype {
        position: relative;
    }

        #divlicensetype .dropdown-menu {
            position: absolute !important;
            z-index: 1200 !important;
            max-height: 250px;
            overflow-y: auto;
            width: max-content;
            min-width: 200px;
        }

        #divlicensetype > button {
            width: 100%;
            text-align: left;
        }


    .is-invalid {
        border-color: #dc3545;
    }

    .error-border {
        border: 2px solid red !important;
    }

    .error-radio {
        border: 1px solid #dc3545;
        padding: 2px;
        border-radius: 2px;
    }

    button:disabled {
        cursor: not-allowed;
        opacity: 0.6;
    }

</style>
