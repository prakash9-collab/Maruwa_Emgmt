    </script>

    <!-- i18next JavaScript for language switching -->
    <script>
        // Initialize i18next
        i18next
            .use(i18nextXHRBackend) // Use XHR backend to load JSON translation files
            .init({
                lng: 'en-US',  // Default language
                fallbackLng: 'en-US',  // Fallback language if translation not available
                debug: true,
                backend: {
                    loadPath: '/i18n/{{lng}}.json' // Path to the translation files
                }
            }, function(err, t) {
                updateContent();// Initialize content after translations are loaded
            });

        // Function to update the content based on translations
        function updateContent() {
            // Loop through elements with "data-i18n" and update them
            document.querySelectorAll('[data-i18n]').forEach(function(element) {
                const key = element.getAttribute('data-i18n');
                element.innerHTML = i18next.t(key);
            });
        }

        // Language dropdown change event
        document.getElementById('langSelect').addEventListener('change', function() {
            const lang = this.value; // Get selected language
            i18next.changeLanguage(lang, function() {
                updateContent(); // Update content after language change
            });

            localStorage.setItem('appLanguage', lang);
        });

        // On page load: set the default language from localStorage or fallback to 'en-US'
        let savedLang = localStorage.getItem('appLanguage') || 'en-US';
        document.getElementById('langSelect').value = savedLang; // Set the dropdown value
        i18next.changeLanguage(savedLang, function() {
            updateContent(); // Update content based on the saved language
        });
    </script>

