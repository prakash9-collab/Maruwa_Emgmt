@using System.Text.Json
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    string isLoggedIn = HttpContextAccessor.HttpContext.Session.GetString("EmployeeDetails");// Get serialized employee object from session
    var userRole = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    var role = userRole?.ToUpperInvariant();
    string empName = "";
    string empCode = "";
    if (!string.IsNullOrEmpty(isLoggedIn))
    {
        var employee = JsonSerializer.Deserialize<tblempmaster>(isLoggedIn);
        empName = employee?.empname ?? "";
        empCode = employee?.empcode ?? "";
    }
    // New Code for Auto Logout
    bool isLoggedIn_ = !string.IsNullOrEmpty(isLoggedIn);
    var session = HttpContextAccessor.HttpContext.Session;
    var path = HttpContextAccessor.HttpContext.Request.Path.Value?.ToLower();// Exclude Login page
    bool isLoginPage = path != null && path.Contains("/loginuser/login");
    // if (!isLoggedIn_ && !isLoggedIn_)
    // {
    //     Context.Response.Redirect("/LoginUser/Login");
    // }
    if (!isLoggedIn_ && !isLoginPage)
    {
        ViewBag.SessionExpired = true;
    }
}

