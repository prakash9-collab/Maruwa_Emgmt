<?xml version="1.0" encoding="utf-8"?>
<log4net>
	<!-- Rolling File Appender -->
	<appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
		<!-- Dynamic folder path set in Program.cs -->
		<file type="log4net.Util.PatternString" value="%property{LogPath}/log.txt" />

		<!-- Roll daily -->
		<rollingStyle value="Composite" />

		<!-- File name pattern -->
		<datePattern value="dd_MM_yyyy'.txt'" />

		<!-- Max size of a single log file -->
		<maximumFileSize value="10MB" />

		<!-- Keep all files, optionally set maxRollBackups -->
		<maxSizeRollBackups value="10" />

		<staticLogFileName value="false" />
		<appendToFile value="true" />

		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="%date [%thread] %-5level %logger [%class.%method] - %message%newline" />
		</layout>
	</appender>

	<root>
		<level value="ALL" />
		<appender-ref ref="RollingFileAppender" />
	</root>
</log4net>
